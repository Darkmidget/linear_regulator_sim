.MODEL MMBT3906 PNP (IS=30.517E-15 BF=194.76 VAF=41.589 IKF=0.17 ISE=12.9E-15 NE=1.5 BR=1.139 VAR=7.9 IKR=0.03 ISC=10E-15 NC=1.2 RB=10 RE=0.2 RC=0.2 CJC=4.97E-12 VJC=0.54 MJC=0.33 CJE=11.6E-12 VJE=0.75 MJE=0.33 TF=0.36E-9 TR=7.5E-9)

.MODEL irf4905slpbf PMOS (VTO=-3.5 KP=35 RS=0.015 RD=0.01 RG=2.6 IS=1e-12 N=1.0 VGS=-55 CGSO=2n CGDO=0.5n CGBO=0)

.SUBCKT LM393BIDR 1 2 3 4 5
